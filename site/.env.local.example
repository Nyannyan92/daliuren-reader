# Gemini API 配置（必填）
GEMINI_API_KEY=
# 推荐使用稳定生产版 gemini-2.5-pro；
# gemini-3-pro-preview 当前可能超载或返回 503，仅在容量恢复后再尝试。
GEMINI_MODEL=gemini-2.5-pro

# 代理配置（在中国大陆访问 Google AI Studio 必填）
# 把端口换成你 VPN 客户端实际暴露的 HTTP 代理端口：
#   ClashX / Clash Verge / Clash for Windows 默认 7890
#   Surge / 小猫咪 默认 6152
#   V2RayN / V2RayU 多为 10809 / 1087
# 如果 VPN 是 SOCKS5，也可以试 ALL_PROXY=socks5://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890

# 解读响应超时（可选，单位毫秒）
# - GEMINI_FIRST_CHUNK_TIMEOUT_MS：首字超时，未拿到第一个 chunk 之前生效，默认 90000
# - GEMINI_TOTAL_TIMEOUT_MS：总超时，开始流式输出后兜底，默认 300000
# 模型超载（503）或网络拥塞导致首字常常超过 90s 时，可调高 FIRST_CHUNK，或换稳定模型
# GEMINI_FIRST_CHUNK_TIMEOUT_MS=120000
# GEMINI_TOTAL_TIMEOUT_MS=360000
